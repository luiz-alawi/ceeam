generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  passwordHash String
  name         String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Booking {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userName  String
  userEmail String
  date      String
  time      String
  court     String
  equipment String[] @default([])
  players   String[] @default([])
  // pending | accepted | rejected | cancelled | waitlisted
  status    String   @default("pending")
  // null = ainda não registrado; true = compareceu; false = faltou
  attended  Boolean?
  // agrupa ocorrências criadas por um agendamento recorrente
  recurringGroupId String?
  // justificativa do pedido (usada nos pedidos recorrentes / horário fixo)
  reason    String?
  createdAt DateTime @default(now())

  @@index([userEmail])
  @@index([status])
  @@index([date, time, court])
}

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  text      String
  sender    String
  userEmail String
  createdAt DateTime @default(now())

  @@index([userEmail])
}

model GymClosure {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  date      String
  reason    String
  createdAt DateTime @default(now())

  @@index([date])
}

model WeeklyEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  dayOfWeek Int
  time      String
  court     String
  title     String
  createdAt DateTime @default(now())

  @@index([dayOfWeek])
}

// Regras de agendamento configuráveis pelo admin (documento único).
model Settings {
  id                String @id @default(auto()) @map("_id") @db.ObjectId
  maxPerUserPerWeek Int    @default(3)
  minAdvanceHours   Int    @default(0)
  maxAdvanceDays    Int    @default(30)
  waitlistEnabled   Boolean @default(true)
}

// Trilha de auditoria das ações administrativas.
model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  actorEmail String
  action     String
  target     String?
  details    String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
